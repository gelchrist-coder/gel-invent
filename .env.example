# PostgreSQL Database URL (Supabase/Vercel/Railway/local)
# Supabase format (requires SSL):
# DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.<project-ref>.supabase.co:5432/postgres?sslmode=require
DATABASE_URL=postgresql://postgres:password@host:port/database?sslmode=require

# Optional but recommended: create users in Supabase Authentication (auth.users)
# Set these to sync each new signup/employee to Supabase Auth so they appear in
# Dashboard -> Authentication -> Users.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
