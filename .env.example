# PostgreSQL Database URL (Supabase pooler — required for serverless/Vercel)
# Use the Transaction pooler (port 6543) for the running app:
# DATABASE_URL=postgresql://postgres.<project-ref>:YOUR_PASSWORD@aws-1-<region>.pooler.supabase.com:6543/postgres?sslmode=require
DATABASE_URL=postgresql://postgres.<project-ref>:password@aws-1-<region>.pooler.supabase.com:6543/postgres?sslmode=require


# Optional but recommended: create users in Supabase Authentication (auth.users)
# Set these to sync each new signup/employee to Supabase Auth so they appear in
# Dashboard -> Authentication -> Users.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
