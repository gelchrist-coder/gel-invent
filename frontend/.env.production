# Call the API same-origin via the "/api" proxy rewrite in vercel.json
# (/api/(.*) -> https://gel-invent.vercel.app/$1). Leaving VITE_API_URL empty
# avoids cross-origin CORS + preflight entirely and makes cold-start errors
# retryable instead of surfacing as misleading "CORS blocked" failures.
VITE_API_URL=
